{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5050",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=abr_db;Username=postgres;Password=Admin@123"
  },
  "Jwt": {
    "SecretKey": "ABR-Super-Secret-Key-Change-In-Production-Min32Chars!",
    "Issuer": "ABR.Api",
    "Audience": "ABR.Frontend",
    "ExpiryHours": 8
  },
  "Security": {
    "LicenseFilePath": "config/device.lic",
    "LicenseSecret": "ABR-Device-License-Secret-Change-In-Production!",
    "EnforceDeviceLock": true
  },
  "Export": {
    "PendriveOnly": false,
    "OutputDirectory": "exports"
  }
}
